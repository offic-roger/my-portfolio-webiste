# Gemini AI Chatbot Configuration
# Get your API key from Google AI Studio: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Contact Form Email Delivery Configurations
# Option A: Using Resend (https://resend.com)
RESEND_API_KEY=re_your_resend_api_key_here

# Option B: Using Web3Forms (https://web3forms.com)
# Web3Forms is 100% free and sends emails to rogersmwangomale@gmail.com without setup.
# Register your email at https://web3forms.com to get an access key.
WEB3FORMS_ACCESS_KEY=your_web3forms_access_key_here
